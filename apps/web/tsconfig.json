{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@/lib/*": ["src/lib/*"],
      "@/components/*": ["components/*"]
    },
    "jsx": "preserve",
    "moduleResolution": "NodeNext",
    "allowJs": false,
    "noEmit": true,
    "module": "ESNext"
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx"],
  "exclude": ["node_modules"]
}

{
  "name": "@docunest/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/cli.ts",
    "build": "tsup src/index.ts --dts --format esm,cjs --out-dir dist",
    "start": "node dist/index.js",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts",
    "worker:dev": "tsx src/cli.ts"
  },
  "dependencies": {
    "@docunest/schema": "workspace:*",
    "@docunest/utils": "workspace:*",
    "@prisma/client": "^5.13.0",
    "bullmq": "^5.8.0",
    "ioredis": "^5.4.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "tsup": "^7.2.0",
    "tsx": "^4.7.1"
  }
}

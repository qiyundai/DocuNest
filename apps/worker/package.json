{
  "name": "@docunest/worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker:dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --out-dir dist --dts false",
    "start": "node dist/index.js",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@docunest/schema": "workspace:*",
    "@docunest/utils": "workspace:*",
    "@prisma/client": "5.11.0",
    "@qdrant/js-client-rest": "1.9.0",
    "bullmq": "5.4.2",
    "ioredis": "5.4.1",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/node": "20.11.30",
    "prisma": "5.11.0",
    "tsup": "7.2.0",
    "tsx": "4.7.1"
  }
}

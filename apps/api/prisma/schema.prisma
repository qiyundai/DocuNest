generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String    @id @default(uuid())
  name      String    @unique
  products  Product[]
  manuals   Manual[]
  users     User[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id        String   @id @default(uuid())
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  tenantId  String
  name      String
  model     String
  sku       String   @unique
  manuals   Manual[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Manual {
  id          String           @id @default(uuid())
  tenant      Tenant           @relation(fields: [tenantId], references: [id])
  tenantId    String
  product     Product          @relation(fields: [productId], references: [id])
  productId   String
  manualId    String           @unique
  version     String
  locale      String
  sections    ManualSection[]
  embeddings  EmbeddingChunk[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model ManualSection {
  id         String  @id @default(uuid())
  manual     Manual  @relation(fields: [manualId], references: [id])
  manualId   String
  title      String
  order      Int
  content    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  embeddings EmbeddingChunk[]
}

model EmbeddingChunk {
  id        String @id
  manual    Manual @relation(fields: [manualId], references: [id])
  manualId  String
  section   ManualSection @relation(fields: [sectionId], references: [id])
  sectionId String
  locale    String
  text      String
  vectorId  String?
  createdAt DateTime @default(now())
}

model User {
  id        String  @id @default(uuid())
  tenant    Tenant  @relation(fields: [tenantId], references: [id])
  tenantId  String
  email     String  @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String    @id @default(uuid())
  name      String
  products  Product[]
  manuals   Manual[]
  users     User[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Product {
  id        String    @id @default(uuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  model     String
  sku       String
  manuals   Manual[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([tenantId, sku])
}

model Manual {
  id          String           @id @default(uuid())
  tenantId    String
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productId   String
  product     Product          @relation(fields: [productId], references: [id], onDelete: Cascade)
  manualId    String
  version     String
  locale      String
  sections    ManualSection[]
  embeddings  EmbeddingChunk[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([tenantId, manualId, version, locale])
}

model ManualSection {
  id        String   @id @default(uuid())
  manualId  String
  manual    Manual   @relation(fields: [manualId], references: [id], onDelete: Cascade)
  title     String
  order     Int
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EmbeddingChunk {
  id         String   @id @default(uuid())
  manualId   String
  manual     Manual   @relation(fields: [manualId], references: [id], onDelete: Cascade)
  sectionId  String
  section    ManualSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  locale     String
  text       String
  vector     Float[]?
  externalId String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model User {
  id        String   @id @default(uuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

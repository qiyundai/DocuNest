{
  "name": "@docunest/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/routers/index.ts",
      "default": "./src/server.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --format esm --out-dir dist --dts false",
    "start": "node dist/server.js",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts,.tsx"
  },
  "dependencies": {
    "@docunest/plugins": "workspace:*",
    "@docunest/schema": "workspace:*",
    "@docunest/utils": "workspace:*",
    "@prisma/client": "5.11.0",
    "@qdrant/js-client-rest": "1.9.0",
    "@trpc/server": "10.45.1",
    "bullmq": "5.4.2",
    "cors": "2.8.5",
    "express": "4.18.3",
    "ioredis": "5.4.1",
    "superjson": "1.13.3",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "@types/express": "4.17.21",
    "@types/node": "20.11.30",
    "prisma": "5.11.0",
    "ts-node": "10.9.2",
    "tsup": "7.2.0",
    "tsx": "4.7.1"
  }
}

{
  "name": "@docunest/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsup src/server.ts --dts --format esm,cjs --out-dir dist",
    "start": "node dist/server.js",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@docunest/plugins": "workspace:*",
    "@docunest/schema": "workspace:*",
    "@docunest/utils": "workspace:*",
    "@prisma/client": "^5.13.0",
    "@trpc/server": "^10.45.0",
    "bullmq": "^5.8.0",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "superjson": "^1.13.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.7",
    "prisma": "^5.13.0",
    "ts-node": "^10.9.2",
    "tsup": "^7.2.0",
    "tsx": "^4.7.1"
  }
}

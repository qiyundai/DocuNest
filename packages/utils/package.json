{
  "name": "@docunest/utils",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs",
    "dev": "tsup src/index.ts --watch",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "dotenv": "16.4.5",
    "pino": "8.19.0",
    "pino-pretty": "10.3.1",
    "zod": "3.22.4"
  },
  "devDependencies": {
    "tsup": "7.2.0"
  }
}
